# Copy to .env.production on the server (gitignored). Soccer beta minimum.
# Also copy non-secret defaults to project-root .env for docker compose substitution.

ENVIRONMENT=production
OPENAPI_DOCS_ENABLED=false
LOG_LEVEL=INFO

# Required — generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_SECRET
PUSH_CRON_SECRET=REPLACE_WITH_RANDOM_CRON_SECRET

# /internal defense in depth (nginx also denies public /internal — P0-006).
# 127.0.0.1/32 = loopback; 172.16.0.0/12 = host cron → docker published port (gateway IP).
INTERNAL_ALLOWED_CIDRS=127.0.0.1/32,172.16.0.0/12

POSTGRES_PASSWORD=REPLACE_STRONG_DB_PASSWORD
# Self-hosted Docker (default VPS):
DATABASE_URL=postgresql://postgres:REPLACE_STRONG_DB_PASSWORD@postgres:5432/sportsprediction
# Managed Postgres (after P5-003 cutover — TLS required, see docs/MANAGED_POSTGRES_MIGRATION.md):
# DATABASE_URL=postgresql://APP_USER:PASSWORD@db-host.example.com:25060/sportsprediction?sslmode=require
REDIS_URL=redis://redis:6379/0
# Required in production — docker redis --requirepass; API uses password= (not embedded in URL).
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# CORS — mobile + web payment pages
CORS_ORIGINS=["https://api.octobetiq.com","https://www.octobetiq.com","https://octobetiq.com"]

# ClearSports — primary data provider (NFL, NBA, soccer schedules + standings)
CLEARSPORTS_API_KEY=
CLEARSPORTS_API_BASE_URL=https://api.clearsportsapi.com
# CLEARSPORTS_NFL_SEASON=2025
# CLEARSPORTS_NBA_SEASON=2025
# Optional season label for EPL feed (defaults to current Aug–Jul season, e.g. 2024-2025)
# CLEARSPORTS_SOCCER_SEASON_PREMIER_LEAGUE=2024-2025
# Soccer beta: sync only these leagues (comma-separated). Empty = all configured.
SOCCER_SYNC_LEAGUES=premier_league
# Cron predictions: backfill finished games for feed/demo (days), optional league filter
PREDICTION_INCLUDE_FINISHED_DAYS=14
PREDICTION_LEAGUES=premier_league

# ML pickles mounted at /models in docker-compose
EXPLANATION_MODEL_DIR=/models
# Fail closed once publish-ready pickles are deployed to /models (see docs/MODEL_ARTIFACT_BOM.md)
# ALLOW_HEURISTIC_INFERENCE=false
# REQUIRE_PUBLISH_READY_MODEL=true

# Legacy Sportradar — deprecated; do not set when using ClearSports above.
# SPORTRADAR_API_KEY=

# App Store Review demo verify (password not in git — see docs/APP_REVIEW_DEMO_ACCOUNT.md)
# VERIFY_DEMO_EMAIL=appstore-review@octobetiq.com
# VERIFY_DEMO_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_PREMIUM_ANNUAL=
STRIPE_PRICE_ID_PREMIUM_PLUS=
# REVENUECAT_WEBHOOK_AUTH=REPLACE_WITH_LONG_RANDOM_WEBHOOK_SECRET
# REVENUECAT_SECRET_API_KEY=sk_REPLACE_WITH_REVENUECAT_SECRET_API_KEY
STRIPE_SUCCESS_URL=https://www.octobetiq.com/payment/success
STRIPE_CANCEL_URL=https://www.octobetiq.com/payment/cancel

# Optional offsite DB backup (see docs/DATABASE_BACKUP.md)
# OFFSITE_BACKUP_SCP_TARGET=backup@backup.example.com:/var/backups/octobetiq/
# OFFSITE_BACKUP_S3_URI=s3://your-bucket/octobetiq/db/

# Optional monitoring
SENTRY_DSN=
