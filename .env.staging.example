# Copy to .env.staging on the server (gitignored). Staging API on port 8001.
# Quick setup: ./scripts/setup_staging_env.sh

ENVIRONMENT=staging
OPENAPI_DOCS_ENABLED=true
LOG_LEVEL=DEBUG

# Unique secrets — do not reuse production JWT / cron secrets.
JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_SECRET
PUSH_CRON_SECRET=REPLACE_WITH_RANDOM_CRON_SECRET

# Reuses prod Docker postgres/redis (see docker-compose.staging.yml).
POSTGRES_PASSWORD=REPLACE_SAME_AS_PRODUCTION_POSTGRES_PASSWORD
REDIS_PASSWORD=REPLACE_SAME_AS_PRODUCTION_REDIS_PASSWORD

DATABASE_URL=postgresql://postgres:REPLACE_SAME_AS_PRODUCTION_POSTGRES_PASSWORD@postgres:5432/sportsprediction_staging
REDIS_URL=redis://redis:6379/1

INTERNAL_ALLOWED_CIDRS=127.0.0.1/32,172.16.0.0/12
CORS_ORIGINS=["https://api-staging.octobetiq.com","http://localhost:19006"]

# Stripe test mode only on staging
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
STRIPE_PRICE_ID_PREMIUM=price_REPLACE_TEST_MONTHLY
STRIPE_PRICE_ID_PREMIUM_ANNUAL=price_REPLACE_TEST_ANNUAL
STRIPE_PRICE_ID_PREMIUM_PLUS=
STRIPE_SUCCESS_URL=https://www.octobetiq.com/payment/success
STRIPE_CANCEL_URL=https://www.octobetiq.com/payment/cancel

# Optional — use test/sandbox keys only
CLEARSPORTS_API_KEY=
SENTRY_DSN=
