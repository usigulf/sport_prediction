# Sport prediction — host crontab snippets (adjust paths and times).
# Install: chmod +x scripts/cron/*.sh && crontab -e
#
# Requires: PUSH_CRON_SECRET in ~/sport_prediction/.env
# Optional: API_INTERNAL_URL=http://127.0.0.1:8000 (default)
#
# After deploy, verify soccer provider (must cd to repo — not from ~):
#   cd /root/sport_prediction && VERIFY_API_BASE=http://127.0.0.1:8000 ./scripts/verify_clearsports_prod.sh .env.production
#
# In .env / .env.production on the server:
#   CLEARSPORTS_API_KEY=...         # primary: soccer + NFL + NBA schedule sync
#   CLEARSPORTS_NFL_SEASON=2025     # optional; inferred if unset
#   CLEARSPORTS_NBA_SEASON=2025
#   SPORTRADAR_API_KEY=...          # fallback for NFL/NBA only if ClearSports key empty
#   SOCCER_SYNC_LEAGUES=premier_league  # optional soccer filter
#   PREDICTION_INCLUDE_FINISHED_DAYS=14
#   PREDICTION_LEAGUES=              # empty = all leagues with upcoming games
#   MODEL_TRAIN_MIN_GAMES=60         # weekly retrain aborts below this unless MODEL_TRAIN_FORCE=true
#   MODEL_TRAIN_FORCE=false
#   MODEL_TRAIN_REFRESH_PREDICTIONS=true  # after train, run internal_predictions_run.sh
#
# Premier League real features (health → sync → predictions → sample upcoming):
#   cd /home/YOU/sport_prediction && chmod +x scripts/setup_premier_league_features.sh
#   VERIFY_API_BASE=http://127.0.0.1:8000 ./scripts/setup_premier_league_features.sh .env

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Live in-play pipeline: scores + inplay_v0 ML when any game is live (no-op otherwise)
*/2 * * * * /root/sport_prediction/scripts/cron/internal_live_sync_run.sh >> /tmp/sport-prediction-cron.log 2>&1

# Predictions refresh every 20 minutes (pick 15–60 to taste)
*/20 * * * * /root/sport_prediction/scripts/cron/internal_predictions_run.sh >> /tmp/sport-prediction-cron.log 2>&1

# Freeze closing odds near kickoff (closing-line ledger / model-vs-market acceptance)
*/15 * * * * /root/sport_prediction/scripts/cron/internal_odds_freeze_closing.sh >> /tmp/sport-prediction-cron.log 2>&1

# Push: favorite-team game reminders + high-confidence pick alerts (every 15 min)
*/15 * * * * /root/sport_prediction/scripts/cron/internal_push_triggers_run.sh >> /tmp/sport-prediction-cron.log 2>&1

# Soccer fixtures (ClearSports or Sportradar) ~3x daily (UTC)
30 6,14,22 * * * /root/sport_prediction/scripts/cron/internal_soccer_sync_schedules.sh >> /tmp/sport-prediction-cron.log 2>&1

# NFL + NBA schedules (ClearSports; requires CLEARSPORTS_API_KEY) ~3x daily (UTC)
45 6,14,22 * * * /root/sport_prediction/scripts/cron/internal_us_sports_sync_schedules.sh >> /tmp/sport-prediction-cron.log 2>&1

# Retrain win-probability model weekly (Sunday 05:15 UTC) after weekend results land.
# Or install idempotently: ./scripts/setup_weekly_train_cron.sh
15 5 * * 0 /root/sport_prediction/scripts/cron/internal_train_model.sh >> /tmp/sport-prediction-cron.log 2>&1

# M-07 historical backfill: prior seasons for training corpus (Sunday 04:00 UTC, monthly-ish load)
0 4 1 * * /root/sport_prediction/scripts/cron/internal_historical_backfill.sh >> /tmp/sport-prediction-cron.log 2>&1

# Daily Postgres backup (local pg_dump) + optional offsite copy (03:00 UTC)
# Or install idempotently: ./scripts/setup_db_backup_cron.sh
0 3 * * * /root/sport_prediction/scripts/run_pg_backup.sh >>/var/log/pg_backup.log 2>&1

# Verify backups after daily run (03:30 UTC); set OFFSITE_REQUIRED=1 once offsite is configured
30 3 * * * OFFSITE_REQUIRED=1 /root/sport_prediction/scripts/verify_db_backup.sh >>/var/log/pg_backup_verify.log 2>&1

# API uptime probe (/health + /ready) every 5 minutes
*/5 * * * * /root/sport_prediction/scripts/check_api_health.sh >>/var/log/api_health.log 2>&1

# Quarterly ASC App Privacy review (I85) — 9am UTC on 15th of Jan/Apr/Jul/Oct
0 9 15 1,4,7,10 * /root/sport_prediction/scripts/asc_privacy_review_reminder.sh >>/var/log/asc_privacy_review.log 2>&1

# */10 * * * * /root/sport_prediction/scripts/check_staging_health.sh >>/var/log/staging_health.log 2>&1
