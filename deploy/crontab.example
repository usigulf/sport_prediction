# Sport prediction — host crontab snippets (adjust paths and times).
# Install: chmod +x scripts/cron/*.sh && crontab -e
#
# Requires: PUSH_CRON_SECRET in ~/sport_prediction/.env
# Optional: API_INTERNAL_URL=http://127.0.0.1:8000 (default)
#
# After deploy, verify soccer provider (must cd to repo — not from ~):
#   cd /root/sport_prediction && VERIFY_API_BASE=http://127.0.0.1:8000 ./scripts/verify_clearsports_prod.sh .env.production
#
# In .env / .env.production on the server:
#   CLEARSPORTS_API_KEY=...         # primary: soccer + NFL + NBA schedule sync
#   CLEARSPORTS_NFL_SEASON=2025     # optional; inferred if unset
#   CLEARSPORTS_NBA_SEASON=2025
#   SPORTRADAR_API_KEY=...          # fallback for NFL/NBA only if ClearSports key empty
#   SOCCER_SYNC_LEAGUES=premier_league  # optional soccer filter
#   PREDICTION_INCLUDE_FINISHED_DAYS=14
#   PREDICTION_LEAGUES=              # empty = all leagues with upcoming games
#
# Premier League real features (health → sync → predictions → sample upcoming):
#   cd /home/YOU/sport_prediction && chmod +x scripts/setup_premier_league_features.sh
#   VERIFY_API_BASE=http://127.0.0.1:8000 ./scripts/setup_premier_league_features.sh .env

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Predictions refresh every 20 minutes (pick 15–60 to taste)
*/20 * * * * /root/sport_prediction/scripts/cron/internal_predictions_run.sh >> /tmp/sport-prediction-cron.log 2>&1

# Soccer fixtures (ClearSports or Sportradar) ~3x daily (UTC)
30 6,14,22 * * * /root/sport_prediction/scripts/cron/internal_soccer_sync_schedules.sh >> /tmp/sport-prediction-cron.log 2>&1

# NFL + NBA schedules (Sportradar; requires SPORTRADAR_API_KEY) ~3x daily (UTC)
45 6,14,22 * * * /root/sport_prediction/scripts/cron/internal_us_sports_sync_schedules.sh >> /tmp/sport-prediction-cron.log 2>&1
