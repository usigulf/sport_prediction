# Example nginx site for api.octobetiq.com (TLS paths are Certbot-specific on the server).
#
# Install:
#   sudo cp deploy/nginx-octobetiq-api.conf.example /etc/nginx/sites-available/octobetiq-api
#   sudo ln -sf /etc/nginx/sites-available/octobetiq-api /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Prereq: map $http_upgrade $connection_upgrade in http {} (see deploy/nginx-api-ws-snippet.conf).

server {
    server_name api.octobetiq.com;

    include /etc/nginx/snippets/octobetiq-deny-internal.conf;

    location /ws/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/api.octobetiq.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.octobetiq.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    listen 80;
    server_name api.octobetiq.com;
    return 301 https://$host$request_uri;
}
