        "EXPO_PUBLIC_BETA_SOCCER_ONLY": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "20.18.1",
      "env": {
        "EXPO_PUBLIC_BETA_SOCCER_ONLY": "false"
      }
    },
    "production": {
