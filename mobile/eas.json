        "EXPO_PUBLIC_ADMOB_NATIVE_IOS": "ca-app-pub-1914108971892809/7349098862",
        "EXPO_PUBLIC_ADMOB_REWARDED_IOS": "ca-app-pub-1914108971892809/8510137296",
        "EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS": "ca-app-pub-1914108971892809/9251687566"
      }
    }
