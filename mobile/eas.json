{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BETA_SOCCER_ONLY": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "20.18.1",
      "env": {
        "EXPO_PUBLIC_BETA_SOCCER_ONLY": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "node": "20.18.1",
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.octobetiq.com/api/v1",
        "EXPO_PUBLIC_BETA_SOCCER_ONLY": "false",
        "EXPO_PUBLIC_ADMOB_PRODUCTION": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "8QFCTR7BAL",
        "ascAppId": "6762173223"
      },
      "android": {
        "serviceAccountKeyPath": "./secrets/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
