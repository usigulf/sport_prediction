{
  "name": "sport-prediction-mobile",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:pod-install": "cd ios && bundle install && bundle exec pod install",
    "web": "expo start --web",
    "postinstall": "node scripts/fix-hermesc-macos.js",
    "update:production": "EAS_NO_VCS=1 npx eas-cli update --channel production --environment production --non-interactive",
    "update:preview": "npx eas-cli update --channel preview --non-interactive",
    "eas:build:ios": "EAS_NO_VCS=1 npx eas-cli build --platform ios --profile production",
    "eas:build:android": "EAS_NO_VCS=1 npx eas-cli build --platform android --profile production",
    "eas:submit:ios": "EAS_NO_VCS=1 npx eas-cli submit --platform ios --profile production --latest --wait",
    "eas:submit:ios:ci": "EAS_NO_VCS=1 npx eas-cli submit --platform ios --profile production --latest --non-interactive --wait",
    "eas:submit:android": "EAS_NO_VCS=1 npx eas-cli submit --platform android --profile production --latest",
    "screenshots:ios": "bash scripts/capture-app-store-screenshots.sh all",
    "screenshots:ios:guest": "bash scripts/capture-app-store-screenshots.sh guest",
    "screenshots:ios:auth": "bash scripts/capture-app-store-screenshots.sh auth",
    "screenshots:figma-prep": "bash scripts/prepare-figma-screenshot-assets.sh",
    "screenshots:figma-import": "bash scripts/import-figma-exports.sh",
    "screenshots:figma": "bash scripts/capture-app-store-screenshots.sh auth-auto && bash scripts/prepare-figma-screenshot-assets.sh",
    "screenshots:import": "bash scripts/import-external-screenshots.sh",
    "app-store:preview": "bash scripts/record-app-store-preview.sh",
    "app-store:captions": "bash scripts/build-asc-screenshots.sh",
    "test": "jest",
    "widget:verify": "bash ../scripts/verify_widget_api.sh",
    "test:ci": "jest --ci",
    "codegen:api": "openapi-typescript ../docs/openapi.json -o src/types/api.generated.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^1.9.7",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "^0.29.24",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-purchases": "^10.2.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "eas-cli": "^18.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.1.3"
  },
  "private": true,
  "overrides": {
    "@xmldom/xmldom": "0.8.10",
    "tar": "^7.5.19"
  }
}
