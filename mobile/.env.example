# Production API (required for EAS production builds)
EXPO_PUBLIC_API_URL=https://api.octobetiq.com/api/v1

# Set true for soccer-only beta; false shows Soccer + NFL + NBA.
# Production/TestFlight default should be false.
EXPO_PUBLIC_BETA_SOCCER_ONLY=false

# AdMob — create app + ad units in AdMob console, then set (required for store builds).
# Use your own unit IDs from AdMob; placeholders below are not real values.
# EXPO_PUBLIC_ADMOB_PRODUCTION=true
# EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_BANNER_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_BANNER_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_NATIVE_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_NATIVE_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY

# Or use EAS secrets: eas secret:create --scope project --name EXPO_PUBLIC_ADMOB_BANNER_IOS --value ...

# RevenueCat (in-app purchases). Public SDK keys are safe to ship; prefer platform keys.
# Falls back to the key in app.config.js when unset. Create products + an offering in
# the RevenueCat dashboard with entitlements `premium` and `pro`.
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_REPLACE_WITH_REVENUECAT_IOS_PUBLIC_KEY
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_REPLACE_WITH_REVENUECAT_ANDROID_PUBLIC_KEY

# PostHog product analytics (optional). When unset, all track calls are no-ops.
# EXPO_PUBLIC_POSTHOG_API_KEY=phc_REPLACE_WITH_POSTHOG_PROJECT_API_KEY
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
