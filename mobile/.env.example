# Optional — copy to `.env` for local Expo (never commit secrets)
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Product analytics (I44) — no-op when unset
# EXPO_PUBLIC_POSTHOG_API_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Feature flags (server also exposes /config/feature-flags)
# EXPO_PUBLIC_ODDS_DISPLAY_ENABLED=true

# Subscription offer phase (audit #19): invite_founder (default) | public_list
# EXPO_PUBLIC_OFFER_PHASE=invite_founder
