# Offsite Postgres backup copy — copy to secrets/backup_offsite.env on the VPS (gitignored).
# Used by scripts/run_pg_backup.sh after local pg_dump.
#
# Quick setup:
#   ./scripts/setup_offsite_backup.sh
# Or copy this file manually:
#   cp docs/backup_offsite.env.example secrets/backup_offsite.env && chmod 600 secrets/backup_offsite.env

# Option A: SCP to a second host (SSH key auth required)
# OFFSITE_BACKUP_SCP_TARGET=backup@backup.example.com:/var/backups/octobetiq/

# Option B: AWS S3 or DigitalOcean Spaces (requires aws CLI on VPS)
# OFFSITE_BACKUP_S3_URI=s3://octobetiq-backups/db/
# AWS_ACCESS_KEY_ID=your_spaces_key
# AWS_SECRET_ACCESS_KEY=your_spaces_secret
# AWS_DEFAULT_REGION=nyc3
# AWS_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com

# Optional overrides (defaults match pg_backup_docker.sh)
# BACKUP_DIR=/root/backups
# RETENTION_DAYS=14
