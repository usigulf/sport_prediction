# Offsite Postgres backup copy — copy to secrets/backup_offsite.env on the VPS (gitignored).
# Used by scripts/run_pg_backup.sh after local pg_dump.

# Option A: SCP to a second host (SSH key auth required)
# OFFSITE_BACKUP_SCP_TARGET=backup@backup.example.com:/var/backups/octobetiq/

# Option B: AWS S3 (requires aws CLI on VPS)
# OFFSITE_BACKUP_S3_URI=s3://your-bucket/octobetiq/db/

# Optional overrides (defaults match pg_backup_docker.sh)
# BACKUP_DIR=/root/backups
# RETENTION_DAYS=14
