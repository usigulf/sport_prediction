# Optional: override defaults (copy to .env)
#
# Docker: the API loads backend/.env (this path), not the project-root .env. Either put Stripe (and
# other secrets) here on the server, or inject them with docker-compose `environment` so they exist
# in the container process env (then restart the api container).

# Database (default: SQLite ./app.db)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsprediction

# Redis (optional). Set to empty or "disabled" to skip Redis for /ready and use in-memory rate limiting.
# REDIS_URL=redis://localhost:6379/0

# Trust X-Forwarded-For for rate-limit IP keying only when behind a trusted reverse proxy that sets it.
# Leave unset/false if clients can reach the API directly (otherwise XFF can be spoofed).
# TRUST_FORWARDED_HEADERS=true
# Optional defense in depth for /internal/* cron endpoints: comma-separated CIDRs allowed to call them.
# Production (docker on VPS): 127.0.0.1/32,172.16.0.0/12 — see .env.production.example
# INTERNAL_ALLOWED_CIDRS=127.0.0.1/32,172.16.0.0/12

# Internal cron + /internal/* routes (generate: openssl rand -base64 32)
# PUSH_CRON_SECRET=REPLACE_WITH_RANDOM_CRON_SECRET

# Production: set a strong secret (min 32 chars). Required when ENVIRONMENT=production.
# Generate: openssl rand -base64 32
# JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_SECRET

# Environment (development | production). Production startup logs a critical warning if JWT_SECRET is weak.
# ENVIRONMENT=development

# Set OPENAPI_DOCS_ENABLED=false in production to disable /docs and /redoc.
# OPENAPI_DOCS_ENABLED=false

# CORS: comma-separated origins for API (e.g. https://app.yourapp.com). See config.py defaults.
# CORS_ORIGINS=https://app.yourapp.com,https://www.yourapp.com

# ClearSports API (optional; Sportradar migration). GET /internal/health/clearsports with X-Cron-Secret
# CLEARSPORTS_API_BASE_URL=https://api.clearsportsapi.com
# CLEARSPORTS_API_KEY=

# Stripe (Premium + Pro). Create two recurring Prices in Stripe Dashboard.
# STRIPE_SECRET_KEY=sk_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
# STRIPE_PRICE_ID_PREMIUM=price_REPLACE_WITH_PREMIUM_PRICE_ID
# STRIPE_PRICE_ID_PREMIUM_PLUS=price_REPLACE_WITH_PRO_PRICE_ID
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET
#   Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_SUCCESS_URL=https://www.octobetiq.com/payment/success
# STRIPE_CANCEL_URL=https://www.octobetiq.com/payment/cancel

# RevenueCat (in-app purchases). Set the Authorization header value you configure on the
# RevenueCat dashboard webhook (RevenueCat → Integrations → Webhooks):
#   URL: https://YOUR_HOST/api/v1/subscription/revenuecat/webhook
# The app sets RevenueCat app_user_id to the backend user id, so events map to a user.
# REVENUECAT_WEBHOOK_AUTH=REPLACE_WITH_LONG_RANDOM_WEBHOOK_SECRET
# REVENUECAT_SECRET_API_KEY=sk_REPLACE_WITH_REVENUECAT_SECRET_API_KEY
# Entitlement ids (defaults shown): pro → premium_plus, premium → premium.
# REVENUECAT_ENTITLEMENT_PRO=pro
# REVENUECAT_ENTITLEMENT_PREMIUM=premium

# The Odds API (M-01 — optional). Market odds reuse CLEARSPORTS_API_KEY when this is unset.
# ODDS_API_KEY=
# ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
# ODDS_API_REGIONS=us
# ODDS_API_MARKETS=h2h,spreads,totals
# ODDS_API_CACHE_TTL_SECONDS=300

# Password reset (optional SMTP). When SMTP is unset, reset links are logged server-side only.
# PASSWORD_RESET_LINK_BASE=com.sportsprediction.app://reset-password
# PASSWORD_RESET_LINK_BASE=https://www.octobetiq.com/reset-password.html
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@octobetiq.com
# SMTP_USE_TLS=true
