# Database Configuration
# Docker Compose: set POSTGRES_PASSWORD in project .env so postgres + api DATABASE_URL stay in sync.
# If postgres_data already exists, changing this does not update the DB; run ALTER USER or reset the volume.
# Production: do not expose Postgres/Redis to the internet (compose binds them to 127.0.0.1; use UFW deny 5432,6379).
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sportsprediction
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
# If Redis is unreachable, the API uses an in-process cache fallback (dev/single-worker); use Redis in production for shared rate limits and daily prediction counts.

# JWT Configuration (docker compose api service reads this from project .env)
JWT_SECRET=your-secret-key-change-in-production-minimum-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Configuration
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006","https://app.sportsprediction.com"]

# ML Inference Configuration
ML_INFERENCE_URL=http://localhost:8501
ML_MODEL_VERSION=v1.0.0
# Directory with simple_model.pkl + feature_columns.pkl (train: cd ml/training && python train_simple_model.py)
EXPLANATION_MODEL_DIR=
# Optional override for inference only; defaults to EXPLANATION_MODEL_DIR
MODEL_ARTIFACT_DIR=
# Secret for internal routes: predictions run, push triggers, player-spotlights, GET /internal/health/sportradar
PUSH_CRON_SECRET=gTgoo2Nnx2xTFc/KmiT6oksA8OlBnFU6

# External API Keys
SPORTRADAR_API_KEY=your-sportradar-api-key
SPORTRADAR_API_URL=https://api.sportradar.com
# trial | production (path segment for NFL v7 standings)
SPORTRADAR_ACCESS_LEVEL=trial
# Optional: season year (YYYY). Unset = current UTC calendar year.
# Soccer Global API v4: season ids from Sportradar "Seasons" (e.g. sr:season:130281). Required for PL/UCL provider notes.
# SPORTRADAR_SOCCER_SEASON_PREMIER_LEAGUE=sr:season:130281
# SPORTRADAR_SOCCER_SEASON_CHAMPIONS_LEAGUE=sr:season:...
# SPORTRADAR_NFL_SEASON_YEAR=2025
WEATHER_API_KEY=your-weather-api-key

# Monitoring
SENTRY_DSN=your-sentry-dsn-optional
LOG_LEVEL=INFO

# AWS Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_MODELS=sport-prediction-models

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Configuration (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@sportsprediction.com

# Environment
ENVIRONMENT=development
