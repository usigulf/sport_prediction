{
  "name": "sportoracle",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered sports prediction platform",
  "scripts": {
    "dev": "cd mobile && npm start",
    "build": "cd backend && docker build -t sport-prediction-api .",
    "test": "pytest backend/tests -c pytest.ini",
    "test:backend": "pytest backend/tests -c pytest.ini",
    "test:mobile": "cd mobile && npx tsc --noEmit",
    "lint": "cd mobile && npx tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rimraf node_modules mobile/node_modules",
    "mobile:start": "cd mobile && npm start",
    "mobile:ios": "cd mobile && npm run ios",
    "mobile:android": "cd mobile && npm run android",
    "prepare": "node -e \"try{require('husky').default()}catch(e){}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "~19.2.10",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
